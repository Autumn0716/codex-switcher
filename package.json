{
  "name": "code-switcher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "app:dev": "npm run tauri:dev",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build --bundles app",
    "tauri:build:dmg": "tauri build --bundles dmg",
    "linux:build": "tauri build --bundles deb,rpm,appimage",
    "linux:build:docker": "docker build -f packaging/linux/Dockerfile -t code-switcher-linux-builder . && docker run --rm -v \"$(pwd):/workspace\" code-switcher-linux-builder"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/api": "^2.0.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "simple-icons": "^16.18.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
