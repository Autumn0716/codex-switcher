{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Switcher",
  "version": "0.1.0",
  "identifier": "com.autumn0716.codex-switcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codex Switcher",
        "width": 980,
        "height": 660,
        "minWidth": 860,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
